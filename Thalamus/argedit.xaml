<Window x:Class="Thalamus.ArgEdit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compiler Arguments"
        Width="520"
        Height="280"
        Background="#121212"
        Foreground="White"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="g++ Compiler Arguments"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#381bc4"/>

        <TextBox x:Name="ArgsBox"
                 Grid.Row="1"
                 Margin="10,10,0,10"
                 Background="#0D0D0D"
                 Foreground="#AAAAAA"
                 FontFamily="Consolas"
                 FontSize="13"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <Button Content="Cancel"
                    Background="#381bc4"
                    Width="80"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>

            <Button Content="Save"
                    Width="80"
                    Background="#381bc4"
                    Foreground="Black"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
